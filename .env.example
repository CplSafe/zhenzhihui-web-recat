# Server-only Vite proxy targets. Never add the VITE_ prefix: browser code uses
# same-origin /api, /auth, /deepauth and /sso paths.
ZZH_REMOTE_ORIGIN=https://zzh.zhongdahengrui.com
DEEPAUTH_REMOTE_ORIGIN=https://zzh-auth.zhongdahengrui.com
SSO_REMOTE_ORIGIN=http://localhost:8001

# Public browser allowlist used to validate direct object-storage uploads.
VITE_ZZH_ALLOWED_UPLOAD_ORIGINS=

# AI 润色模型(OpenAI 兼容 / vLLM)。dev 经 /aimodel 代理转发以规避 CORS。
# 当前指向本地部署模型;后端正式接入后改这里即可。
AI_MODEL_ORIGIN=http://172.10.0.102:8001
AI_MODEL_NAME=Qwen3.6-35B-A3B
# 专用视觉模型(图片解析:素材分析/智能预填/带图脚本),dev 经 /aimodel-vl 代理
AI_VL_ORIGIN=http://172.10.0.102:8003
AI_VL_NAME=Qwen3-VL-30B-A3B
# AI 图片生成(Qwen-Image),dev 经 /aimodel-img 代理
AI_IMG_ORIGIN=http://172.10.0.102:8004
AI_IMG_NAME=Qwen-Image

# Figma API token（仅脚本/工具链用，勿加 VITE_ 前缀以免泄露到前端 bundle）。
# 真实值写到本地 .env（已 gitignore），切勿提交。
FIGMA_API_KEY=
