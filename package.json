{
  "name": "zhenzhihui-web-react",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:strict": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit:ci": "npm audit --audit-level=moderate --registry=https://registry.npmjs.org",
    "check:bundle": "node scripts/check-client-bundle.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:all": "vitest run --coverage --maxWorkers=1 --coverage.include=\"src/**/*.{ts,tsx}\" --coverage.thresholds.perFile=false --coverage.thresholds.statements=45 --coverage.thresholds.branches=37 --coverage.thresholds.functions=48 --coverage.thresholds.lines=47 --coverage.reportsDirectory=coverage/all",
    "test:typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test:e2e:typecheck": "tsc -p tsconfig.e2e.json --noEmit",
    "test:e2e": "npm run build && playwright test --project=chromium",
    "test:e2e:ci": "playwright test",
    "test:e2e:firefox": "npm run build && playwright test --project=firefox",
    "test:e2e:mobile": "npm run build && playwright test --project=mobile-chromium --project=mobile-webkit",
    "test:e2e:webkit": "npm run build && playwright test --project=webkit",
    "test:e2e:ui": "npm run build && playwright test --project=chromium --ui",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,html}": [
      "prettier --write"
    ]
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not op_mini all",
    "Safari >= 13",
    "iOS >= 13"
  ],
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@openobserve/browser-logs": "^0.3.4",
    "@openobserve/browser-rum": "^0.3.4",
    "antd": "^5.23.0",
    "dayjs": "^1.11.21",
    "normalize.css": "^8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "react-router-dom": "^7.1.1",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.21",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "less": "^4.6.6",
    "lint-staged": "16.2.7",
    "msw": "^2.15.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vite": "^6.3.5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "@openobserve/browser-rum-core": {
      "uuid": "13.0.1"
    }
  }
}
